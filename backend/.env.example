DATABASE_URL=postgresql+psycopg://rag:ragpass@192.168.116.130:5432/rag
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
# 可选：运行 python eval/deepeval_rag.py 时单独指定较小的评判模型以加速
# DEEPEVAL_JUDGE_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
EMBED_DIM=768
RAG_TOP_K=8
CHAT_HISTORY_TURNS=12

# 知识库分区：请求未传 kb_collection 时使用（可选）
DEFAULT_KB_COLLECTION=default

# 离线评测：检索分区与文档类型（可选；也可用命令行 --kb-collection / --doc-types）
EVAL_KB_COLLECTION=default
EVAL_DOC_TYPES=tutorial

# 分块与检索降噪（可选，默认值见 app.config / README）
# CHUNK_MAX_CHARS=720
# CHUNK_OVERLAP=90
# CHUNK_MARKDOWN_BY_HEADING=true
# CHUNK_MARKDOWN_FENCE_AWARE=true
# CHUNK_MERGE_INTRO_BEFORE_FENCE_MAX_CHARS=320
# CHUNK_FENCE_CONTINUATION_PREFIX=true
# CHUNK_CONTINUATION_TITLE_MAX_CHARS=72
# VECTOR_DISTANCE_THRESHOLD=0.38
# TRGM_WORD_SIMILARITY_MIN=0.27
# RAG_TRGM_ONLY_MIN_SIMILARITY=0.32
# RAG_DUAL_WEAK_FILTER=true
# RAG_DUAL_WEAK_MAX_VEC=0.46
# RAG_DUAL_WEAK_MAX_TRGM=0.23
# RAG_GATE_RELAX_FILL=false
# RAG_CITATION_VERIFY=true
# RAG_CITATION_MIN_HITS=2
# RAG_CITATION_MIN_TERM_FRAC=0.02
# RAG_CITATION_MAX_SOURCE_TERMS=100
# RAG_TRGM_INCLUDE_SECTION_HEADING=true
# RAG_CANDIDATE_TOP_K_MULTIPLIER=5
# RAG_MAX_CHUNKS_PER_DOC=4
# RAG_SAME_DOC_PREFETCH_EXTRA=2
# RAG_SAME_DOC_EXPAND_MIN_VEC=0.32
# Parent-Child 分块（开启后子块参与检索，命中后返回父块完整内容给模型）
# CHUNK_PARENT_CHILD=true
# CHUNK_PARENT_MIN_CHARS=200
# CHUNK_PARENT_MAX_CHARS=1500
# Cross-Encoder Reranker（精排，首次请求自动下载模型）
# RAG_RERANK_ENABLED=false
# RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RAG_RERANK_CANDIDATE_K=3

# Web 搜索后端（国内推荐配置其中一项）
# 选项1：Tavily（https://tavily.com 申请，免费1000次/月）
# TAVILY_API_KEY=tvly-xxxxxxxxxxxx
# 选项2：本地 SearXNG 实例（docker run -d -p 8888:8080 searxng/searxng）
# SEARXNG_URL=http://localhost:8888
# 搜索超时（秒，默认8）
# WEB_SEARCH_TIMEOUT=8

# Agent 扩展工具
# python_repl：Python 代码沙箱执行超时（秒，默认15）
# PYTHON_REPL_TIMEOUT=15
# python_repl：最大输出字符数（默认2000）
# PYTHON_REPL_MAX_OUTPUT_CHARS=2000
# fetch_url：网页抓取超时（秒，默认15）
# FETCH_URL_TIMEOUT=15
# fetch_url：提取正文最大字符数（默认4000）
# FETCH_URL_MAX_CHARS=4000

# Plan & Execute 模式
# 规划最大步骤数（默认6）
# PLAN_MAX_STEPS=6

# Agent 推理策略（均默认开启；关闭可减少额外 LLM 调用耗时）
# 强制 CoT 格式：要求 LLM 每次工具调用前输出 "Thought: ..." 推理（默认true）
# AGENT_COT_ENABLED=true
# Self-Ask 问题分解：ReAct 前额外调用 LLM 拆解子问题（默认true）
# AGENT_SELF_ASK_ENABLED=true
# Self-Ask 触发最小字符数：问题短于此值跳过分解（默认20）
# AGENT_SELF_ASK_MIN_CHARS=20
# Reflection 反思：每轮工具后评估信息充分性，充足则提前停止（默认true）
# AGENT_REFLECTION_ENABLED=true

# 知识图谱（轻量级，存储于 PostgreSQL，不需要额外数据库）
# 总开关（默认true；false 时退化为纯向量记忆搜索）
# KG_ENABLED=true
# 写入记忆时同步提取三元组（额外一次 LLM 调用，默认true）
# KG_TRIPLE_EXTRACT_ENABLED=true
# 实体向量去重阈值（余弦距离，默认0.15，越小越严格）
# KG_ENTITY_DEDUP_THRESHOLD=0.15
# 图谱展开跳数（默认2；跳数越多上下文越丰富但越慢）
# KG_GRAPH_HOPS=2
# 实体检索相关性距离上限（默认0.5）
# KG_ENTITY_DISTANCE_THRESHOLD=0.5
