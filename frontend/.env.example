FASTAPI_BASE_URL=http://127.0.0.1:8000

# ── Sentry（前端错误率/异常聚合，可选） ──
# DSN 为空则不启用
# NEXT_PUBLIC_SENTRY_DSN=https://<public_key>@o<org>.ingest.sentry.io/<project_id>
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=dev
# 性能追踪/回放可选（默认 0 不采样）
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
